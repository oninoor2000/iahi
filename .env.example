PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Production host (no trailing slash). Default in repo is Vercel; set this on Vercel / in .env. Use custom domain when ready.
# PUBLIC_SITE_URL=https://iahi.vercel.app
# Direct Postgres URI (Settings → Database → Connection string, port 5432) — for npm run db:migrate-seed
SUPABASE_DB_URL=
# Optional: trigger static rebuild after CMS publish
REBUILD_HOOK_URL=
REBUILD_HOOK_SECRET=

# --- Supabase Auth email (Custom SMTP Gmail) ---
# Hosted Supabase: set in Dashboard → Project Settings → Authentication → SMTP (not in this file).
# Supabase expects SMTP username + password. OAuth "Client ID / Client Secret" (Gmail API) cannot be pasted there.
# For a normal @gmail.com account: enable 2-Step Verification → Google Account → App passwords → create one → use it below for local CLI only.
# GMAIL_SMTP_USER=you@gmail.com
# GMAIL_SMTP_APP_PASSWORD=xxxx xxxx xxxx xxxx
# GMAIL_SMTP_FROM=you@gmail.com

# --- Supabase Auth URLs (hosted project; fix localhost in verification emails) ---
# Dashboard → Authentication → URL Configuration:
#   Site URL: https://iahi.vercel.app (or custom domain)
#   Redirect URLs: https://iahi.vercel.app/**  (+ https://iahi.or.id/** if you use both), and http://localhost:4321/** for local dev
