---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { createBuildTimeSupabaseClient } from '@/lib/supabase/build';

let branches: Array<{ name: string; region: string | null; slug: string }> = [];
try {
  const supabase = createBuildTimeSupabaseClient();
  const { data } = await supabase
    .from('branches')
    .select('name, region, slug')
    .order('display_order', { ascending: true });
  branches = data ?? [];
} catch {
  branches = [];
}

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Beranda', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Tentang', item: new URL('/tentang', Astro.site).href },
  ],
};
---

<BaseLayout
  title="Tentang IAHI | Indonesian Association of Health Informatics"
  description="Sejarah, keanggotaan, struktur organisasi, dan jejaring cabang wilayah IAHI."
  jsonLd={breadcrumbLd}
>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="text-4xl font-semibold tracking-tight text-primary">Tentang IAHI</h1>
    <p class="mt-6 text-muted-foreground leading-relaxed">
      Indonesian Association of Health Informatics (IAHI) didirikan pada tahun 2005 sebagai wadah
      profesional bagi praktisi, peneliti, dan pemangku kepentingan informatika kesehatan di
      Indonesia. Kami mendukung pengembangan kapasitas, standar profesional, dan kolaborasi berbasis
      bukti untuk mendorong sistem kesehatan yang aman, adil, dan berkelanjutan.
    </p>
    <h2 class="mt-12 text-2xl font-semibold text-primary">Keanggotaan</h2>
    <p class="mt-4 text-muted-foreground leading-relaxed">
      Keanggotaan mencakup kategori <strong class="text-foreground">individu</strong> dan{' '}
      <strong class="text-foreground">institusi</strong>. Calon anggota mendaftar secara daring;
      aktivasi dilakukan setelah pemeriksaan administrasi oleh tim pengurus.
    </p>
    <h2 class="mt-12 text-2xl font-semibold text-primary">Cabang wilayah</h2>
    {branches.length === 0 ? (
      <p class="mt-4 text-sm text-muted-foreground">
        Data cabang akan tampil setelah basis data Supabase dikonfigurasi.
      </p>
    ) : (
      <ul class="mt-4 grid gap-3 sm:grid-cols-2">
        {branches.map((b) => (
          <li class="rounded-lg border border-border bg-card px-4 py-3 text-sm shadow-sm">
            <span class="font-medium text-foreground">{b.name}</span>
            {b.region ? <span class="mt-1 block text-muted-foreground">{b.region}</span> : null}
          </li>
        ))}
      </ul>
    )}
  </article>
</BaseLayout>
