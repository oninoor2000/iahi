---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { createBuildTimeSupabaseClient } from '@/lib/supabase/build';
import { PUBLIC_SITE_FALLBACK } from '@/lib/site';

export async function getStaticPaths() {
  try {
    const supabase = createBuildTimeSupabaseClient();
    const { data } = await supabase.from('articles').select('slug').eq('status', 'published');
    return (data ?? []).map((row) => ({ params: { slug: row.slug } }));
  } catch {
    return [];
  }
}

const { slug } = Astro.params;
if (!slug) {
  throw new Error('Missing slug');
}

const supabase = createBuildTimeSupabaseClient();
const { data: article } = await supabase
  .from('articles')
  .select(
    'title, slug, excerpt, content_html, published_at, cover_image_url, meta_title, meta_description, category, author_id',
  )
  .eq('slug', slug)
  .eq('status', 'published')
  .maybeSingle();

if (!article) {
  return Astro.redirect('/artikel');
}

const { data: authorProf } = await supabase
  .from('profiles')
  .select('full_name')
  .eq('id', article.author_id)
  .maybeSingle();

const title = article.meta_title ?? article.title;
const description =
  article.meta_description ?? article.excerpt ?? `Artikel: ${article.title} — IAHI`;
const siteOrigin = Astro.site?.origin ?? PUBLIC_SITE_FALLBACK;
const canonicalPath = `/artikel/${article.slug}`;
const ogImage = article.cover_image_url
  ? article.cover_image_url.startsWith('http')
    ? article.cover_image_url
    : `${siteOrigin}${article.cover_image_url}`
  : undefined;

const authorName = authorProf?.full_name ?? 'IAHI';

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: article.title,
  datePublished: article.published_at ?? undefined,
  author: { '@type': 'Person', name: authorName },
  image: ogImage ? [ogImage] : undefined,
  mainEntityOfPage: new URL(canonicalPath, siteOrigin).href,
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Beranda', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Artikel', item: new URL('/artikel', Astro.site).href },
    {
      '@type': 'ListItem',
      position: 3,
      name: article.title,
      item: new URL(canonicalPath, Astro.site).href,
    },
  ],
};

const contentClass =
  'mt-10 max-w-none leading-relaxed text-foreground [&_a]:text-primary [&_blockquote]:border-l-2 [&_blockquote]:border-primary/40 [&_blockquote]:pl-4 [&_h2]:mt-10 [&_h2]:text-2xl [&_h2]:font-semibold [&_h3]:mt-8 [&_h3]:text-xl [&_h3]:font-semibold [&_h4]:mt-6 [&_h4]:text-lg [&_h4]:font-semibold [&_li]:my-1 [&_ol]:my-4 [&_ol]:list-decimal [&_ol]:pl-6 [&_p]:my-4 [&_ul]:my-4 [&_ul]:list-disc [&_ul]:pl-6';
---

<BaseLayout
  title={`${title} | IAHI`}
  description={description}
  canonicalPath={canonicalPath}
  ogType="article"
  ogImage={ogImage}
  jsonLd={[breadcrumbLd, articleLd]}
>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <header>
      <p class="text-sm text-muted-foreground">
        {article.published_at ? (
          <time datetime={article.published_at}>
            {new Date(article.published_at).toLocaleDateString('id-ID', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        ) : null}
        {article.category ? <span class="before:mx-2 before:content-['·']">{article.category}</span> : null}
      </p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-primary">{article.title}</h1>
      <p class="mt-3 text-sm text-muted-foreground">Oleh {authorName}</p>
    </header>
    {
      article.cover_image_url ? (
        <figure class="mt-10 overflow-hidden rounded-lg border border-border shadow-sm">
          <img
            src={article.cover_image_url}
            alt=""
            class="h-auto w-full object-cover"
            loading="lazy"
            width="1200"
            height="630"
          />
        </figure>
      ) : null
    }
    <div class={contentClass} set:html={article.content_html} />
  </article>
</BaseLayout>
