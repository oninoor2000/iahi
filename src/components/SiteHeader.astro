---
const { user, isAdmin } = Astro.locals;
---

<header class="border-b border-border/80 bg-card/80 backdrop-blur-sm sticky top-0 z-50">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-6 px-4 sm:px-6">
    <a href="/" class="text-lg font-semibold tracking-tight text-primary">
      IAHI
    </a>
    <nav class="hidden items-center gap-6 text-sm font-medium text-muted-foreground md:flex">
      <a href="/tentang" class="transition-colors hover:text-foreground">Tentang</a>
      <a href="/artikel" class="transition-colors hover:text-foreground">Artikel</a>
      <a href="/fiki" class="transition-colors hover:text-foreground">FIKI</a>
      {user ? (
        <>
          <a href="/dashboard" class="transition-colors hover:text-foreground">Dashboard</a>
          {isAdmin ? (
            <a href="/admin" class="transition-colors hover:text-foreground">Admin</a>
          ) : null}
        </>
      ) : (
        <>
          <a href="/login" class="transition-colors hover:text-foreground">Masuk</a>
          <a
            href="/daftar"
            class="rounded-md bg-primary px-3 py-1.5 text-primary-foreground shadow-sm transition-opacity hover:opacity-90"
          >
            Daftar
          </a>
        </>
      )}
    </nav>
    <details class="relative md:hidden">
      <summary class="cursor-pointer list-none text-sm font-medium text-primary">Menu</summary>
      <div class="absolute right-0 mt-2 flex w-48 flex-col gap-2 rounded-md border border-border bg-card p-3 text-sm shadow-sm">
        <a href="/tentang">Tentang</a>
        <a href="/artikel">Artikel</a>
        <a href="/fiki">FIKI</a>
        {user ? (
          <>
            <a href="/dashboard">Dashboard</a>
            {isAdmin ? <a href="/admin">Admin</a> : null}
          </>
        ) : (
          <>
            <a href="/login">Masuk</a>
            <a href="/daftar">Daftar</a>
          </>
        )}
      </div>
    </details>
  </div>
</header>
